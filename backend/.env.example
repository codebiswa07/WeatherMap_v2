# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/weathermap

# Open-Meteo — completely free, no API key needed!
# Forecast API
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
# Geocoding API (city name -> lat/lon)
OPEN_METEO_GEO_URL=https://geocoding-api.open-meteo.com/v1

# Cache TTL (seconds)
CACHE_TTL=600

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000
